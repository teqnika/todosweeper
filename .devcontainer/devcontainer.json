{
  "name": "Swipe Todo",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:22-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  "postCreateCommand": "npm install --prefix frontend && npm install --prefix worker && npm --prefix frontend run playwright:install",

  "forwardPorts": [5173, 8787],
  "portsAttributes": {
    "5173": { "label": "Vite (frontend)", "onAutoForward": "openBrowser" },
    "8787": { "label": "Wrangler (worker)", "onAutoForward": "silent" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "cloudflare.cloudflare-workers-bindings",
        "clinyong.vscode-css-modules"
      ],
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "typescript.tsdk": "frontend/node_modules/typescript/lib",
        "css.validate": false,
        "cssModules.camelCase": true
      }
    }
  },

  "remoteEnv": {
    "VITE_API_URL": "http://localhost:8787"
  }
}
